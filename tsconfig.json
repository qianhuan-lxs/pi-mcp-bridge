{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "lib": ["ES2022", "DOM"],
    "types": ["node"]
  },
  "include": [
    "*.ts",
    "registry/**/*.ts",
    "__tests__/**/*.ts",
    "examples/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "build"]
}
