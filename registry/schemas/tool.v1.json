{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pi-mcp-bridge.dev/schemas/tool.v1.json",
  "title": "pi-mcp-bridge tool definition",
  "type": "object",
  "required": ["name", "description", "inputSchema"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "name": {
      "type": "string",
      "description": "Original MCP tool name (sent to tools/call)."
    },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "inputSchema": {
      "type": "object",
      "description": "JSON Schema for the tool's arguments."
    },
    "outputSchema": { "type": "object" },
    "annotations": {
      "type": "object",
      "properties": {
        "readOnlyHint": { "type": "boolean" },
        "destructiveHint": { "type": "boolean" },
        "idempotentHint": { "type": "boolean" },
        "openWorldHint": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "ui": {
      "type": "object",
      "properties": {
        "resourceUri": { "type": ["string", "null"] },
        "streamMode": { "enum": ["eager", "stream-first"], "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "_meta": { "type": "object" }
  }
}
